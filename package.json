{
  "name": "arbeidsplassen-playwright",
  "version": "1.0.0",
  "description": "End-to-end tests for Arbeidsplassen using Playwright",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "test": "DEBUG_COLORS=false playwright test",
    "test:dev-e2e": "DEBUG_COLORS=false playwright test dev-e2e",
    "test:prod-uptest": "DEBUG_COLORS=false playwright test prod-uptest",
    "test:localhost": "LOCALHOST=true DEBUG_COLORS=false playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.59.1",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
